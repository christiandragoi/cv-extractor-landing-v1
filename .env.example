# =============================================================================
# CV Extractor - Environment Configuration
# Copy this file to .env and fill in real values
# =============================================================================

# --- App ---
ENVIRONMENT=development
SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=                   # Base64-encoded 32-byte key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./cv_extractor_local.db
# For production: DATABASE_URL=postgresql+asyncpg://cv_user:cv_pass@localhost:5432/cvextractor

# --- Redis (optional, for Celery background tasks) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_ROOT=./storage_local

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost

# --- AI Provider (legacy / fallback - prefer DB-configured providers) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=                  # Optional custom endpoint
