# Local development environment
# Uses SQLite - no PostgreSQL or Redis needed!
ENVIRONMENT=development
SECRET_KEY=local-dev-secret-key-not-for-production
DATABASE_URL=sqlite+aiosqlite:///./cv_extractor_local.db
REDIS_URL=redis://localhost:6379/0
STORAGE_BACKEND=local
STORAGE_ROOT=./storage_local
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8001,http://127.0.0.1:8001
OPENAI_API_KEY=
